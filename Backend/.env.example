# Required for intent classification, OCR, response editing and translation.
GROQ_API_KEY=

# Optional model overrides.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
CAPTION_MODEL=Salesforce/blip-image-captioning-large

# Required by the Hugging Face object-detection inference API.
HF_API_TOKEN=
OBJECT_DETECTION_MODEL=facebook/detr-resnet-50

# Server settings.
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=*
MAX_UPLOAD_MB=10

